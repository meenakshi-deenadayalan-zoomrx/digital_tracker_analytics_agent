# DTSA MCP Server — Environment Configuration
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Extension DB read replica ────────────────────────────────────────────────
DTSA_EXTENSION_DB_READ_HOST=
DTSA_EXTENSION_DB_READ_PORT=3306
DTSA_EXTENSION_DB_READ_NAME=extn
DTSA_EXTENSION_DB_READ_USERNAME=
DTSA_EXTENSION_DB_READ_PASSWORD=

# ── Code investigation (choose one) ─────────────────────────────────────────
# Option A: GitHub API (PAT with repo:read scope)
DTSA_GITHUB_TOKEN=
DTSA_GITHUB_ORG=ZoomRx

# Option B: Local repo clones (path to the folder containing all 5 repos)
# Leave blank if using GitHub token above.
DTSA_LOCAL_REPOS_BASE=

# ── Phabricator (Conduit API — create-only token) ────────────────────────────
DTSA_PHABRICATOR_API_TOKEN=
DTSA_PHABRICATOR_API_URL=
